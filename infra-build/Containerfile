# syntax=docker/dockerfile:1
#
# Multi-arch (linux/amd64, linux/arm64) build for dora.
# Build from the REPO ROOT (the build context needs the whole workspace), e.g.:
#   podman build -f infra-build/Containerfile -t dora .
#   docker buildx build --platform linux/amd64,linux/arm64 -f infra-build/Containerfile -t dora .
#
# The runtime base is the Iron Bank hardened UBI 10 image, which requires
# authenticating to registry1.dso.mil first (see the CI `docker` job).

# ---- builder ----
# The Rust image is multi-arch, so under `buildx --platform` it builds natively
# for each target architecture.
FROM rust:1 AS builder
WORKDIR /usr/src/dora
# Build against sqlx's offline query cache (crates/libs/ip-manager/sqlx-data.json)
# — the same thing the rest of CI uses — so no sqlx-cli, database, or migrations
# are needed at image-build time.
ENV SQLX_OFFLINE=true
ARG BUILD_MODE=release
COPY . .
# BuildKit cache mounts keep the cargo registry and the compiled `target/` dir
# out of the image layers and let CI persist them across builds (restored via
# reproducible-containers/buildkit-cache-dance). The dominant build cost is
# recompiling dora's own crates; with a warm `target` mount an ordinary source
# edit recompiles only what changed instead of the whole workspace. The binary
# lives inside the mounted target dir, so copy it out before the mount is
# released at the end of the RUN.
RUN --mount=type=cache,target=/usr/local/cargo/registry,sharing=locked \
    --mount=type=cache,target=/usr/local/cargo/git,sharing=locked \
    --mount=type=cache,target=/usr/src/dora/target,sharing=locked \
    cargo build --${BUILD_MODE} --bin dora \
    && cp "target/${BUILD_MODE}/dora" /usr/local/bin/dora

# ---- runtime ----
# Iron Bank hardened UBI 10 (published for linux/amd64 and linux/arm64).
FROM registry1.dso.mil/ironbank/redhat/ubi/ubi10:10.2

# UBI is RHEL-based, so runtime deps come from dnf (not apt). The `dhcpd` user
# was previously provided by the isc-dhcp-server package on Ubuntu; UBI has no
# such package, so create the user/group directly. shadow-utils provides the
# useradd/groupadd/usermod/groupmod that useradd here and the entrypoint need;
# iproute provides `ip`, iputils provides `ping`.
RUN dnf -y install --setopt=install_weak_deps=False --nodocs \
        iproute \
        iputils \
        ca-certificates \
        shadow-utils \
    && dnf clean all \
    && rm -rf /var/cache/dnf \
    && groupadd -r dhcpd \
    && useradd -r -g dhcpd -s /sbin/nologin -d /var/lib/dora dhcpd

COPY --from=builder /usr/local/bin/dora /usr/local/bin/dora

RUN mkdir -p /var/lib/dora/

COPY infra-build/entrypoint.sh /entrypoint.sh
ENTRYPOINT ["/entrypoint.sh"]
